# Optional: override API base (no trailing slash).
# Local dev defaults to /api (Vite proxy). Production defaults to Render URL.
#
# If your deployed site gets CORS errors, either:
# A) Ask backend to allow your frontend origin, or
# B) On Netlify: set VITE_API_ORIGIN=/api and keep public/_redirects (proxy).
#
# VITE_API_ORIGIN=/api
# VITE_API_ORIGIN=https://epss-pod-verification-be.onrender.com
