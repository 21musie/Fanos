# Optional: override API base (no trailing slash on the value you set).
# Local dev defaults to /api (Vite proxy).
#
# Vercel (same origin): omit this or use /api
# VITE_API_ORIGIN=/api
#
# Cross-origin (e.g. dashboard on fanos.epss.gov.et/metadata/): point at the Vercel proxy, **with /api**:
# VITE_API_ORIGIN=https://fanos-dashboard.vercel.app/api
#
# Direct to Render (only if backend CORS allows your site origin):
# VITE_API_ORIGIN=https://epss-pod-verification-be.onrender.com
